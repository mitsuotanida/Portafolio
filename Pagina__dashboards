<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mitsuo Tanida | Portafolio de Analítica Aplicada</title>
  <meta
    name="description"
    content="Portafolio profesional de Mitsuo Tanida: analítica aplicada, Power BI, automatización de reportes y sistemas de apoyo a la decisión."
  />

  <!-- Open Graph: esto ayuda a que LinkedIn muestre una tarjeta más linda cuando compartes la web -->
  <meta property="og:title" content="Mitsuo Tanida | Portafolio de Analítica Aplicada" />
  <meta
    property="og:description"
    content="Portafolio profesional orientado a analítica aplicada, visualización de datos y automatización de procesos para la toma de decisiones basada en evidencia."
  />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://TU-USUARIO.github.io/" />
  <meta property="og:image" content="https://TU-USUARIO.github.io/preview.png" />
  <meta name="theme-color" content="#0b1220" />

  <style>
    /*
      IDEA SIMPLE:
      - :root guarda colores y tamaños importantes, como una cajita con reglas base.
      - Así puedes cambiar el estilo completo tocando pocas líneas.
    */
    :root {
      --bg: #07111f;
      --bg-soft: #0b1220;
      --panel: rgba(15, 23, 42, 0.78);
      --panel-strong: rgba(15, 23, 42, 0.95);
      --line: rgba(148, 163, 184, 0.18);
      --text: #e5eefc;
      --muted: #9fb0c9;
      --accent: #67e8f9;
      --accent-2: #8b5cf6;
      --accent-3: #22c55e;
      --shadow: 0 18px 60px rgba(2, 8, 23, 0.45);
      --radius-xl: 28px;
      --radius-lg: 20px;
      --radius-md: 14px;
      --container: 1160px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(103, 232, 249, 0.14), transparent 30%),
        radial-gradient(circle at top right, rgba(139, 92, 246, 0.16), transparent 25%),
        linear-gradient(180deg, #07111f 0%, #0a1428 100%);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
    }

    .container {
      width: min(100% - 32px, var(--container));
      margin: 0 auto;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(15, 23, 42, 0.55);
      color: var(--muted);
      font-size: 0.92rem;
      backdrop-filter: blur(10px);
    }

    .pill-dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      box-shadow: 0 0 16px rgba(103, 232, 249, 0.7);
    }

    .section {
      padding: 84px 0;
    }

    .section-header {
      max-width: 760px;
      margin-bottom: 28px;
    }

    .eyebrow {
      color: var(--accent);
      font-weight: 700;
      font-size: 0.88rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .section-title {
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.1;
      margin-bottom: 12px;
    }

    .section-copy {
      color: var(--muted);
      font-size: 1.02rem;
    }

    /* Header */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: blur(16px);
      background: rgba(7, 17, 31, 0.72);
      border-bottom: 1px solid rgba(148, 163, 184, 0.08);
    }

    .nav {
      min-height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      font-weight: 800;
      letter-spacing: 0.01em;
    }

    .brand-mark {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(103, 232, 249, 0.18), rgba(139, 92, 246, 0.28));
      border: 1px solid rgba(103, 232, 249, 0.16);
      box-shadow: var(--shadow);
      font-weight: 800;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 18px;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: var(--muted);
      font-size: 0.96rem;
      transition: color 0.2s ease;
    }

    .nav-links a:hover {
      color: var(--text);
    }

    .nav-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 18px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), #7dd3fc);
      color: #04111d;
      font-weight: 800;
      box-shadow: 0 12px 34px rgba(103, 232, 249, 0.22);
    }

    /* Hero */
    .hero {
      padding: 72px 0 36px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 28px;
      align-items: stretch;
    }

    .hero-card,
    .glass-card,
    .project-card,
    .focus-card,
    .timeline-card,
    .contact-card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .hero-card {
      padding: 34px;
      position: relative;
      overflow: hidden;
      isolation: isolate;
    }

    .hero-card::before {
      content: "";
      position: absolute;
      inset: auto -40px -50px auto;
      width: 240px;
      height: 240px;
      background: radial-gradient(circle, rgba(103, 232, 249, 0.18), transparent 62%);
      z-index: -1;
    }

    .hero-title {
      font-size: clamp(2.5rem, 5vw, 4.8rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      margin: 18px 0 18px;
    }

    .hero-title span {
      background: linear-gradient(135deg, #ffffff 0%, #b4c7ec 52%, #67e8f9 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .hero-copy {
      color: var(--muted);
      font-size: 1.08rem;
      max-width: 680px;
      margin-bottom: 26px;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 26px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 50px;
      padding: 0 18px;
      border-radius: 999px;
      font-weight: 800;
      border: 1px solid transparent;
      transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .btn:hover {
      transform: translateY(-2px);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent), #a5f3fc);
      color: #04111d;
      box-shadow: 0 12px 30px rgba(103, 232, 249, 0.22);
    }

    .btn-secondary {
      background: rgba(15, 23, 42, 0.6);
      border-color: var(--line);
      color: var(--text);
    }

    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .stat {
      padding: 16px;
      border-radius: 18px;
      background: rgba(2, 8, 23, 0.28);
      border: 1px solid rgba(148, 163, 184, 0.12);
    }

    .stat strong {
      display: block;
      font-size: 1.35rem;
      margin-bottom: 4px;
    }

    .stat span {
      color: var(--muted);
      font-size: 0.92rem;
    }

    .hero-side {
      display: grid;
      gap: 18px;
    }

    .glass-card {
      padding: 24px;
    }

    .profile-top {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 18px;
    }

    .avatar {
      width: 64px;
      height: 64px;
      border-radius: 20px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(103, 232, 249, 0.16), rgba(139, 92, 246, 0.22));
      border: 1px solid rgba(103, 232, 249, 0.15);
      font-size: 1.2rem;
      font-weight: 800;
    }

    .profile-role {
      color: var(--muted);
      font-size: 0.95rem;
    }

    .mini-list {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .mini-item {
      padding: 14px;
      border-radius: 16px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      background: rgba(2, 8, 23, 0.25);
    }

    .mini-item strong {
      display: block;
      margin-bottom: 4px;
    }

    .mini-item span {
      color: var(--muted);
      font-size: 0.94rem;
    }

    /* About */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }

    .panel-block {
      padding: 28px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
    }

    .panel-block p {
      color: var(--muted);
      margin-bottom: 14px;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .tag {
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(2, 8, 23, 0.28);
      border: 1px solid rgba(148, 163, 184, 0.14);
      color: #d7e4f9;
      font-size: 0.92rem;
    }

    /* Focus */
    .focus-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 18px;
    }

    .focus-card {
      padding: 24px;
    }

    .focus-number {
      font-size: 0.82rem;
      color: var(--accent);
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .focus-card h3 {
      margin-bottom: 10px;
      font-size: 1.14rem;
    }

    .focus-card p {
      color: var(--muted);
      font-size: 0.96rem;
    }

    /* Projects */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
    }

    .project-card {
      padding: 24px;
      display: flex;
      flex-direction: column;
      min-height: 100%;
    }

    .project-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 16px;
    }

    .project-type {
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(103, 232, 249, 0.1);
      color: var(--accent);
      border: 1px solid rgba(103, 232, 249, 0.14);
      font-size: 0.82rem;
      font-weight: 700;
      white-space: nowrap;
    }

    .project-card h3 {
      font-size: 1.18rem;
      margin-bottom: 10px;
    }

    .project-card p {
      color: var(--muted);
      margin-bottom: 16px;
      flex-grow: 1;
    }

    .project-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 18px;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #dffaff;
      font-weight: 700;
    }

    /* Timeline */
    .timeline {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .timeline-card {
      padding: 24px;
    }

    .timeline-card h3 {
      margin-bottom: 12px;
    }

    .timeline-steps {
      display: grid;
      gap: 14px;
    }

    .timeline-step {
      display: grid;
      grid-template-columns: 44px 1fr;
      gap: 12px;
      align-items: start;
    }

    .step-index {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      background: rgba(103, 232, 249, 0.1);
      border: 1px solid rgba(103, 232, 249, 0.14);
      font-weight: 800;
      color: var(--accent);
    }

    .timeline-step p {
      color: var(--muted);
    }

    /* Contact */
    .contact-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 18px;
    }

    .contact-card {
      padding: 28px;
    }

    .contact-links {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 18px;
    }

    .contact-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 16px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(2, 8, 23, 0.28);
      color: var(--text);
      font-weight: 700;
    }

    .availability {
      display: grid;
      gap: 12px;
      margin-top: 16px;
    }

    .availability div {
      padding: 14px;
      border-radius: 16px;
      background: rgba(2, 8, 23, 0.25);
      border: 1px solid rgba(148, 163, 184, 0.12);
      color: var(--muted);
    }

    .availability strong {
      color: var(--text);
      display: block;
      margin-bottom: 4px;
    }

    /* Footer */
    .site-footer {
      padding: 28px 0 44px;
      color: var(--muted);
      font-size: 0.94rem;
    }

    .footer-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      flex-wrap: wrap;
      border-top: 1px solid rgba(148, 163, 184, 0.1);
      padding-top: 22px;
    }

    /* Responsive */
    @media (max-width: 1080px) {
      .hero-grid,
      .about-grid,
      .timeline,
      .contact-grid {
        grid-template-columns: 1fr;
      }

      .focus-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .projects-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 720px) {
      .nav {
        flex-direction: column;
        align-items: flex-start;
        padding: 14px 0;
      }

      .nav-links {
        gap: 12px;
      }

      .hero {
        padding-top: 34px;
      }

      .hero-card,
      .glass-card,
      .panel-block,
      .project-card,
      .focus-card,
      .timeline-card,
      .contact-card {
        border-radius: 22px;
      }

      .hero-card {
        padding: 24px;
      }

      .hero-stats,
      .focus-grid,
      .projects-grid {
        grid-template-columns: 1fr;
      }

      .section {
        padding: 64px 0;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container nav">
      <a class="brand" href="#inicio" aria-label="Ir al inicio">
        <span class="brand-mark">MT</span>
        <span>Mitsuo Tanida</span>
      </a>

      <nav class="nav-links" aria-label="Navegación principal">
        <a href="#sobre-mi">Sobre mí</a>
